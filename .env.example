# Azure Resource Guardian — Environment Configuration
# ======================================================
# Copy this file to `.env` in the project root and fill in real values:
#   cp .env.example .env
#
# Generate secure values for SECRET_KEY and ENCRYPTION_KEY with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"                       # SECRET_KEY
#   python3 -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"  # ENCRYPTION_KEY
#
# NEVER commit a real .env file to version control. It's already in .gitignore.

# ---------------------------------------------------------------------------
# PostgreSQL (required — no default, docker-compose will refuse to start without it)
# ---------------------------------------------------------------------------
POSTGRES_USER=arg
POSTGRES_PASSWORD=changeme-use-a-real-password
POSTGRES_DB=arg
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Application secrets (required — defaults in code are placeholders only)
# ---------------------------------------------------------------------------
# 64-character hex string used to sign JWT access/refresh tokens.
SECRET_KEY=555a91eb3af29ee8ad4c032fe1fc16757e1966646ff4129f75696436d782610e

# Base64-encoded 32-byte AES-256 key used to encrypt Azure service principal
# credentials at rest in the database. Losing this key means losing access
# to every stored credential — back it up securely outside of git.
ENCRYPTION_KEY=ASLwhkDDs39COUMIgYrFnlZUhVq0VFmHROT6CwIn9Zs=

# ---------------------------------------------------------------------------
# Initial admin user (created by scripts/seed_admin.py on first run)
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@local.dev
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-before-first-login

# ---------------------------------------------------------------------------
# Password reset (optional) — works without any of these set: reset links
# are logged server-side (docker compose logs backend) instead of emailed.
# Set SMTP_HOST to enable real email delivery.
# ---------------------------------------------------------------------------
# FRONTEND_BASE_URL=http://localhost:3000
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@yourcompany.com

# ---------------------------------------------------------------------------
# Microsoft OAuth / "Sign in with Microsoft" (optional) — the "Sign in
# with Microsoft" button on the login page only appears when BOTH
# AZURE_OAUTH_CLIENT_ID and AZURE_OAUTH_CLIENT_SECRET are set below.
# This is a separate Azure AD app registration from the per-tenant
# scanning Service Principals configured in Settings — register a new
# app with redirect URI matching AZURE_OAUTH_REDIRECT_URI, add the
# "User.Read" delegated Graph permission, and create a client secret.
# Note: a user must already have a local ARG account with a matching
# email before they can sign in with Microsoft — this app does not
# auto-provision new accounts.
# ---------------------------------------------------------------------------
# AZURE_OAUTH_CLIENT_ID=
# AZURE_OAUTH_CLIENT_SECRET=
# AZURE_OAUTH_TENANT_ID=common
# AZURE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/microsoft/callback

# ---------------------------------------------------------------------------
# Application behavior
# ---------------------------------------------------------------------------
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
DOCS_ENABLED=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Ports (host-side; change if these conflict with something already running)
# ---------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ---------------------------------------------------------------------------
# Worker scaling
# ---------------------------------------------------------------------------
WORKER_REPLICAS=2
UVICORN_WORKERS=4

# ---------------------------------------------------------------------------
# Feature flags (sensible defaults — override if needed)
# ---------------------------------------------------------------------------
FEATURE_TERRAFORM_DRIFT=true
FEATURE_ENTRA_HYGIENE=true
FEATURE_COST_ANALYSIS=true
FEATURE_AUTO_REMEDIATION=false
FEATURE_SCHEDULED_SCANS=true
FEATURE_WEBHOOKS=true

# ---------------------------------------------------------------------------
# Webhooks (optional — leave blank to disable)
# ---------------------------------------------------------------------------
WEBHOOK_SLACK_URL=
WEBHOOK_TEAMS_URL=
WEBHOOK_CUSTOM_URL=
WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Scanner tuning (optional — defaults are sane for most environments)
# ---------------------------------------------------------------------------
SCANNER_TIMEOUT_SECONDS=300
SCANNER_MAX_CONCURRENT=10
FULL_SCAN_SCHEDULE=0 2 * * *
SCAN_RESULT_RETENTION_DAYS=90
