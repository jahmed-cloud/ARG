# Azure Resource Guardian — .gitignore
# ======================================

# ── Secrets (NEVER commit these) ────────────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
secrets/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyc
*.pyo

# Virtual environments
.venv/
venv/
ENV/
env/
.env/

# Pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
*.xml
nosetests.xml
coverage.xml

# mypy / pyright
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
pyrightconfig.json

# ── Node / Frontend ──────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.next/
frontend/out/
frontend/.nuxt/
frontend/.cache/
frontend/.parcel-cache/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
.yarn-integrity

# ── Docker ───────────────────────────────────────────────────────────────────
# Don't ignore docker-compose.yml or Dockerfiles — those belong in git.
# Do ignore local override files.
docker-compose.override.yml
docker-compose.local.yml

# ── Alembic ──────────────────────────────────────────────────────────────────
# Keep all migration files — they're part of the schema history.
# Only ignore the __pycache__ inside migrations.
backend/migrations/versions/__pycache__/

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride

# JetBrains
*.iml
*.iws
.idea/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Reports / Outputs ────────────────────────────────────────────────────────
# Generated report files (stored in the DB + disk by the app at runtime)
reports/
*.pdf
*.xlsx
*.csv

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
nohup.out

# ── Test artifacts ───────────────────────────────────────────────────────────
.hypothesis/
htmlcov/

# ── Terraform state (if any local TF work) ───────────────────────────────────
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
